# ---- Python ----
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
*.egg-info/
.pytest_cache/

# ---- IDE ----
.vscode/
.idea/
.codebuddy/

# ---- Datasets (large, fetched separately — see docs/DATA_DOWNLOAD.md) ----
data/nerf_synthetic/
data/nerf_llff_data/
data/dtu/
data/mip_nerf_360/
data/_cache/

# Per-scene depth-prior caches generated by scripts/precompute_depth.py
# These can be huge (one .npz per training image per backbone).
**/_depth_cache/
data/**/.cache/

# ---- Pretrained / downloaded model weights ----
# Local snapshot of Depth-Anything-V2 from HuggingFace
# (snapshot_download with local_dir=...; ~99MB Small, ~390MB Base, ~1.3GB Large)
# NOTE: must be root-anchored ("/models/") so we don't accidentally ignore the
# Python package sparse_gs/models/ which contains real source code.
/models/

# ---- Experiment outputs (live training artefacts) ----
outputs/
runs/
wandb/
*.ckpt
*.pt
*.pth
*.npz

# ---- Curated experiment archives (small json/yaml only — DO commit) ----
# results/_sota/   ← committed (SOTA tables)
# results/hotdog_x30k/   ← committed (reference run metrics)
# results/experiments/  ← committed (137 experiment metrics-only snapshots, ~0.43 MB)
!results/**/*.json
!results/**/*.jsonl
!results/**/*.yaml
!results/**/*.csv
!results/**/*.md

# ---- Third-party comparison baselines ----
# Each baseline (CoR-GS / DNGaussian / FSGS / SparseGS) has its own upstream
# repo and license; we keep them locally for side-by-side comparison only and
# do NOT version-control them.  See docs/BASELINES.md for clone instructions.
third_party/

# ---- Misc ----
*.log
outputs/logs/
.DS_Store
Thumbs.db
